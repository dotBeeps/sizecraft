# EditorConfig: https://EditorConfig.org
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml,json,ts,tsx,js,jsx,qml,fish,nix}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.go]
indent_style = tab

[{justfile,Justfile,*.just}]
indent_size = 4
